<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<title>Student List App</title>

</head>

<body>

<nav class="navbar navbar-expand-sm bg-dark navbar-dark">

<div class="container-fluid">

<a class="navbar-brand" href="/">Student List App</a>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse" id="collapsibleNavbar">

<ul class="navbar-nav">

<li class="nav-item">

<a class="nav-link" href="/addStudent">Add new student</a>

</li>

</ul>

</div>

</div>

</nav>

<div class="container">

<br>

<div class="text-center">

<h2>Students from Student List App Database</h2>

</div>

<br>

<table class="table table-hover text-center">

<thead>

<tr>
<th>Student Name</th>
<th>Student Image</th>
<th>Date of Birth</th>
<th>Contact</th>
<th>Edit</th>
<th>Delete</th>
</tr>

</thead>

<tbody>

<% students.forEach(student => { %>

<tr>

<td>

<a href="/student/<%= student.studentId %>">

<%= student.name %>

</a>

</td>

<td>

<img src="/images/<%= student.image %>" width="80">

</td>

<td>

<%= student.dob.toDateString() %>

</td>

<td>

<%= student.contact %>

</td>

<td>

<a href="/editStudent/<%= student.studentId %>">

Edit

</a>

</td>

<td>

<a href="/deleteStudent/<%= student.studentId %>"
onclick="return confirm('Are you sure you want to delete this student?')">

Delete

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>

</html>